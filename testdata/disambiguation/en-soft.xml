<?xml version="1.0" encoding="UTF-8"?>
<rules>
  <!-- Soft POS filter: after "will", keep only VB reading of "run" -->
  <rule id="SOFT_WILL_RUN_VB" name="will run → VB">
    <pattern>
      <token>will</token>
      <token>run</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <!-- Soft replace: force NNP on LanguageTool brand token when capitalized form -->
  <rule id="SOFT_LANGUAGETOOL_NNP" name="LanguageTool → NNP">
    <pattern>
      <token>LanguageTool</token>
    </pattern>
    <disambig action="replace" postag="NNP"/>
  </rule>
  <!-- Soft immunize: protect "as" in "as well" is multiword; immunize single "asap" -->
  <rule id="SOFT_IMMUNIZE_ASAP" name="immunize asap">
    <pattern>
      <token>asap</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
</rules>
