<?xml version="1.0" encoding="UTF-8"?>
<rules>
  <!-- Soft POS filter: after modal, keep VB on the following verb (last token only) -->
  <rule id="SOFT_WILL_RUN_VB" name="will run → VB">
    <pattern>
      <token>will</token>
      <token>run</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_WOULD_RUN_VB" name="would run → VB">
    <pattern>
      <token>would</token>
      <token>run</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_CAN_CAN_VB" name="can can → second VB">
    <pattern>
      <token>can</token>
      <token>can</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_WILL_BOOK_VB" name="will book → VB">
    <pattern>
      <token>will</token>
      <token>book</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_MAY_BOOK_VB" name="may book → VB">
    <pattern>
      <token>may</token>
      <token>book</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_SHOULD_RUN_VB" name="should run → VB">
    <pattern>
      <token>should</token>
      <token>run</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_COULD_RUN_VB" name="could run → VB">
    <pattern>
      <token>could</token>
      <token>run</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_MIGHT_RUN_VB" name="might run → VB">
    <pattern>
      <token>might</token>
      <token>run</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_MUST_BOOK_VB" name="must book → VB">
    <pattern>
      <token>must</token>
      <token>book</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_WILL_READ_VB" name="will read → VB">
    <pattern>
      <token>will</token>
      <token>read</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_CAN_READ_VB" name="can read → VB">
    <pattern>
      <token>can</token>
      <token>read</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <!-- Soft general: modal + common ambiguous verbs → VB on last token -->
  <rule id="SOFT_MODAL_MAKE_VB" name="modal make → VB">
    <pattern>
      <token regexp="yes">will|would|can|could|should|might|must|shall|may</token>
      <token>make</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_MODAL_TAKE_VB" name="modal take → VB">
    <pattern>
      <token regexp="yes">will|would|can|could|should|might|must|shall|may</token>
      <token>take</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_MODAL_SET_VB" name="modal set → VB">
    <pattern>
      <token regexp="yes">will|would|can|could|should|might|must|shall|may</token>
      <token>set</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_MODAL_PLAY_VB" name="modal play → VB">
    <pattern>
      <token regexp="yes">will|would|can|could|should|might|must|shall|may</token>
      <token>play</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <rule id="SOFT_MODAL_WORK_VB" name="modal work → VB">
    <pattern>
      <token regexp="yes">will|would|can|could|should|might|must|shall|may</token>
      <token>work</token>
    </pattern>
    <disambig action="filter" postag="VB"/>
  </rule>
  <!-- Soft replace: force NNP on LanguageTool brand token -->
  <rule id="SOFT_LANGUAGETOOL_NNP" name="LanguageTool → NNP">
    <pattern>
      <token>LanguageTool</token>
    </pattern>
    <disambig action="replace" postag="NNP"/>
  </rule>
  <rule id="SOFT_OPENAI_NNP" name="OpenAI → NNP">
    <pattern>
      <token>OpenAI</token>
    </pattern>
    <disambig action="replace" postag="NNP"/>
  </rule>
  <!-- Soft immunize abbreviations / short forms (speller also skips immunized) -->
  <rule id="SOFT_IMMUNIZE_ASAP" name="immunize asap">
    <pattern>
      <token>asap</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="SOFT_IMMUNIZE_FYI" name="immunize fyi">
    <pattern>
      <token>fyi</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="SOFT_IMMUNIZE_IMO" name="immunize imo">
    <pattern>
      <token>imo</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="SOFT_IMMUNIZE_TLDR" name="immunize tldr">
    <pattern>
      <token>tldr</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="SOFT_IMMUNIZE_BTW" name="immunize btw">
    <pattern>
      <token>btw</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="SOFT_IMMUNIZE_IDC" name="immunize idc">
    <pattern>
      <token>idc</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="SOFT_IMMUNIZE_IRL" name="immunize irl">
    <pattern>
      <token>irl</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="SOFT_IMMUNIZE_OMG" name="immunize omg">
    <pattern>
      <token>omg</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="SOFT_IMMUNIZE_TBH" name="immunize tbh">
    <pattern>
      <token>tbh</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="SOFT_IMMUNIZE_IMO_CAPS" name="immunize IMO">
    <pattern>
      <token>IMO</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="SOFT_IMMUNIZE_LOL" name="immunize lol">
    <pattern>
      <token>lol</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="SOFT_IMMUNIZE_BRB" name="immunize brb">
    <pattern>
      <token>brb</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
</rules>
