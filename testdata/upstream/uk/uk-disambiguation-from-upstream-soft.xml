      <token>да</token>
      <token regexp="yes">Ві́?нчі|[ГҐ]а́?мм?а|Сі́?лва|Карава́?джо|Палестр[іи]на</token>
    </pattern>
    <disambig action="replace" postag="part:pers"/>
  </rule>
  <rule id="vidoma-noun2" name="Відома - іменник">
    <pattern>
      <token regexp="yes">без|до|з|із|для|з-під</token>
      <token regexp="yes">відом[ау]</token>
    </pattern>
    <disambig action="filter" postag="noun:inanim:m:v_(rod|dav).*"/>
  </rule>
  <rule id="myrnoho_atomu" name="Мирного атому">
    <pattern>
      <token regexp="yes">мирного|військового|воєнного|немирного</token>
      <token>атому</token>
    </pattern>
    <disambig action="replace" postag="noun:inanim:m:v_rod"/>
  </rule>
  <rule id="prostori_noun_2" name="просторі - ім.">
    <pattern>
      <token regexp="yes">[ув]|на</token>
      <token>просторі</token>
      <token regexp="yes">[,.]|та|[ій]</token>
    </pattern>
    <disambig action="filter" postag="noun.*"/>
  </rule>
  <rule id="naimu_noun3" name="Найму - іменник">
    <pattern>
      <token>найму</token>
      <token regexp="yes">житла|майна|помешкання|працівників|персоналу</token>
    </pattern>
    <disambig action="filter" postag="noun:inanim:m.*"/>
  </rule>
  <rule id="naimu_ver" name="Найму - іменник">
    <pattern>
      <token regexp="yes">я|собі</token>
      <token>найму</token>
    </pattern>
    <disambig action="filter" postag="verb.*"/>
  </rule>
  <rule id="grata_noninfl_1" name="Нон грата - невідм.">
    <pattern>
      <token>нон</token>
      <token regexp="yes">[гґ]рата|стоп</token>
    </pattern>
    <disambig action="filter" postag="noninfl"/>
  </rule>
  <rule id="grata_noninfl_2" name="Нон ґрата - невідм.">
    <pattern>
      <token>нон</token>
      <token>ґрата</token>
    </pattern>
    <disambig action="replace" postag="noninfl"/>
  </rule>
  <rule id="date_month" name="Місяць дати">
    <pattern>
      <token regexp="yes">[1-3]?[0-9]</token>
      <token regexp="yes">Січ|Лют|Бер|Кві|Тра|Чер|Лип|Сер|Вер|Жов|Лис|Гру</token>
      <token regexp="yes">[0-9]{4}</token>
    </pattern>
    <disambig action="replace" postag="noninfl:abbr"/>
  </rule>
  <rule id="glyb_sing" name="Глиб - одн">
    <pattern>
      <token regexp="yes">[ву]|на</token>
      <token>глиб</token>
    </pattern>
    <disambig action="filter" postag="noun:inanim:m:v_zna.*"/>
  </rule>
  <rule id="obrizka_2" name="Обрізка">
    <pattern>
      <token regexp="yes">для|від|після|щодо|і?з|проти</token>
      <token>обрізки</token>
    </pattern>
    <disambig action="filter" postag="noun:inanim:f.*"/>
  </rule>
  <rule id="td_bad" name="тд - т.д.">
    <pattern>
      <token regexp="yes">[ій]</token>
      <token>тд</token>
    </pattern>
    <disambig action="replace" postag="noninfl:bad"/>
  </rule>
  <rule id="tak_adv" name="так - adv">
    <pattern>
      <token>так</token>
      <token>,</token>
      <token regexp="yes">щоби?</token>
    </pattern>
    <disambig action="filter" postag="adv:pron:dem"/>
  </rule>
  <rule id="prosto_prep" name="просто - прийм.">
    <pattern>
      <token>просто</token>
      <token>неба</token>
    </pattern>
    <disambig action="filter" postag="prep"/>
  </rule>
  <rule id="stalа_noun" name="стала - іменник">
    <pattern>
      <token>стала</token>
      <token regexp="yes">Планка|Больцмана|Ейлера</token>
    </pattern>
    <disambig action="filter" postag="noun.*"/>
  </rule>
  <rule id="zhal_noun1" name="жаль - іменник">
    <pattern>
      <token>на</token>
      <token>жаль</token>
    </pattern>
    <disambig action="filter" postag="noun:inanim:m:v_zna.*"/>
  </rule>
  <rule id="samo_adv1" name="само - прислівник">
    <pattern>
      <token regexp="yes">так|там</token>
      <token>само</token>
    </pattern>
    <disambig action="filter" postag="adv.*"/>
  </rule>
  <rule id="vo_intj" name="во - intj">
    <pattern>
      <token>во</token>
      <token regexp="yes">!.*</token>
    </pattern>
    <disambig action="filter" postag="intj"/>
  </rule>
</rules>
