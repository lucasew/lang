      <token postag="V.+|NC.+|AQ.+" postag_regexp="yes"></token>
      <token postag="NCMS000" marker="yes">prazer</token>
    </pattern>
    <disambig action="filter" postag="NCMS000"/>
  </rule>
  <rule id="NГ“S_PROFESSORES_NCMP000" name="professores aparecia como verbo">
    <pattern>
      <token>nГіs</token>
      <token marker="yes">professores</token>
    </pattern>
    <disambig action="replace" postag="NCMP000"/>
  </rule>
  <rule id="VERBS_THIRD_PERSON_NOT_SECOND_20260511" name="These verbs aren't VMM02S0:PP1CSO00">
    <pattern>
      <token regexp="yes" postag="VMM02S0:PP1CSO00" marker="yes">parece-me|ocorre-me|consta-me|compete-me|cabe-me|apraz-me</token>
    </pattern>
    <disambig action="remove" postag="VMM02S0:PP1CSO00"/>
  </rule>
  <rule id="HГҒ_VERB_20260116" name="In this case HГҒ is VMIP3S0">
    <pattern>
      <token postag="VMIP3S0|VMM02S0" postag_regexp="yes" marker="yes">hГЎ</token>
      <token postag="Z0.+|NC.+|AQ.+" postag_regexp="yes"></token>
    </pattern>
    <disambig action="filter" postag="VMIP3S0"/>
  </rule>
  <rule id="PARA_POR_TODOS_TERMOS_SUBSTANTIVO_PARA_VERBO" name="Adicionar tag de verbo ao substantivo">
    <pattern>
      <token regexp="yes">para|por</token>
      <token regexp="yes">tod[ao]s</token>
      <token marker="yes">termos</token>
      <token postag="N.+|AQ.+" postag_regexp="yes"></token>
    </pattern>
    <disambig action="add">
      <wd pos="VMN01P0"/>
    </disambig>
  </rule>
  <rule id="PORTA_HIFEN_SUBSTANTIVOPLURAL" name="Remove verbs in porta-Substantivo_Plural">
    <pattern>
      <token postag="N.+" postag_regexp="yes" marker="yes">porta</token>
      <token regexp="yes" spacebefore="no">[-]</token>
      <token postag="NC.P.+" postag_regexp="yes" spacebefore="no"></token>
    </pattern>
    <disambig action="remove" postag="V.*"/>
  </rule>
</rules>
