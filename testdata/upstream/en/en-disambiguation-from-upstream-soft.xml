    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="CD_AU" name="ignore spelling of '5 au'">
    <pattern>
      <token regexp="yes">\d+</token>
      <token>au</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="DIFFERENTLY_ABLED" name="ignore spelling of 'differently abled'">
    <pattern>
      <token>differently</token>
      <token>abled</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="NEED_MD" name="needn't is MD">
    <pattern>
      <token marker="yes">need</token>
      <token>n't</token>
    </pattern>
    <disambig action="filter" postag="MD"/>
  </rule>
  <rule id="A_PRIORI_SPELLING" name="ignore spelling of 'a priori'">
    <pattern>
      <token>a</token>
      <token>priori</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="A_POSTERIORI_SPELLING" name="ignore spelling of 'a posteriori'">
    <pattern>
      <token>a</token>
      <token>posteriori</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="DE_FACTO" name="ignore spelling of 'de facto'">
    <pattern>
      <token regexp="yes" case_sensitive="yes">[Dd]e|DE</token>
      <token regexp="yes" case_sensitive="yes">[Ff]acto|FACTO</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="IGNORE_SPELLING_OF_REAIS_SYMBOL" name="ignore spelling of 'R$'">
    <pattern>
      <token case_sensitive="yes" marker="yes">R$</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="IGNORE_SPELLING_OF_SUPERSCRIPT_NUMBERS" name="ignore spelling of 'mc²'">
    <pattern>
      <token regexp="yes" marker="yes">([a-z]|mc|mi|[dkm]m|sp)[²³]</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="IGNORE_SPELLING_OF_WORDS_WITH_UNDERSCORE_OR_AT" name="ignore spelling of things like REMOTE_USER and name@company">
    <pattern>
      <token regexp="yes" marker="yes">[\p{L}\p{Nd}_\-.]+[@_][\p{L}\p{Nd}_\-.]+</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="IGNORE_SPELLING_OF_THOU_WAST" name="ignore spelling of archaic 'thou wast'">
    <pattern>
      <token regexp="yes" case_sensitive="yes" marker="yes">[Tt]hou|THOU</token>
      <token regexp="yes" case_sensitive="yes" marker="yes">[Ww]ast|WAST</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="PLAY_ING" name="ignore spelling of play(ing)">
    <pattern>
      <token postag="VB"></token>
      <token>(</token>
      <token regexp="yes" case_sensitive="yes" marker="yes">ing|ed</token>
      <token>)</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="ON_FLEEK" name="on fleek">
    <pattern>
      <token>on</token>
      <token regexp="yes" case_sensitive="yes" marker="yes">[Ff]leek|FLEEK</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="AHHH" name="ignore spelling of long interjections (ahhhhh)">
    <pattern>
      <token regexp="yes" case_sensitive="yes">[AaOo]h{1,20}|[OA]H{1,20}</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="ING" name="ignore spelling of 'go(ing)'">
    <pattern>
      <token regexp="yes">\(|/</token>
      <token regexp="yes" marker="yes">ing|ed</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="HAWAI_I" name="ignore 'Hawaiʻi'">
    <pattern>
      <token regexp="yes" case_sensitive="yes">Hawai['’`´‘ʻ]i</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="BUG_NO_VB" name="'bug' no VB">
    <pattern>
      <token marker="yes">bug</token>
      <token regexp="yes">fix(es)?|reports?</token>
    </pattern>
    <disambig action="filter" postag="NN.*"/>
  </rule>
  <rule id="CO2_FREE" name="ignore spelling of 'CO₂-free'">
    <pattern>
      <token regexp="yes" case_sensitive="yes">CO₂-([Ff]ree|[Bb]ased|[Nn]eutral|[Cc]ompensat(ing|ed)|[Dd]ependent|[Ii]ndependent)</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="PRAIA_DA" name="ignore spelling of 'Praia da Luz'">
    <pattern>
      <token case_sensitive="yes" marker="yes">Praia</token>
      <token regexp="yes" case_sensitive="yes" marker="yes">d[oa]</token>
      <token regexp="yes" case_sensitive="yes" marker="yes">[A-Z].+</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="WHOLE_NOTHER_IGNORE_SPELLING" name="ignore spelling of 'whole nother'">
    <pattern>
      <token>whole</token>
      <token regexp="yes" case_sensitive="yes" marker="yes">[Nn]other|NOTHER</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="IGNORE_ES_SPELLING" name="ignore spelling of '(es)'">
    <pattern>
      <token>(</token>
      <token case_sensitive="yes" marker="yes">es</token>
      <token>)</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="IGNORE_WHYS_AND_WHEREFORES" name="ignore 'whys and wherefores'">
    <pattern>
      <token marker="yes">whys</token>
      <token>and</token>
      <token>wherefores</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
</rules>
