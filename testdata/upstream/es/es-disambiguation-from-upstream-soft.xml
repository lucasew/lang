    <pattern>
      <token>lo</token>
      <token postag="A.*|V.P,*" postag_regexp="yes" marker="yes"></token>
      <token>que</token>
    </pattern>
    <disambig action="filter" postag="A.*|V.P.*"/>
  </rule>
  <rule id="not_verb_if_agreement" name="not verb if agreement">
    <pattern>
      <token regexp="yes" inflected="yes" postag="_GN_.*" postag_regexp="yes">uno|serie|cena|historia</token>
    </pattern>
    <disambig action="remove" postag="V.[MSI].*"/>
  </rule>
  <rule id="no_verbo2" name="not verb">
    <pattern>
      <token regexp="yes" inflected="yes" postag="N.*" postag_regexp="yes">disparate|cosa|misión|grado|desgracia|pena</token>
    </pattern>
    <disambig action="filter" postag="N.*|_GN_.*"/>
  </rule>
  <rule id="no_verbo3" name="not verb">
    <pattern>
      <token inflected="yes" postag="A.*" postag_regexp="yes">lindo</token>
    </pattern>
    <disambig action="filter" postag="A.*"/>
  </rule>
  <rule id="aloe_vera" name="aloe vera">
    <pattern>
      <token>aloe</token>
      <token>vera</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="un_haiga" name="un haiga">
    <pattern>
      <token>un</token>
      <token marker="yes">haiga</token>
    </pattern>
    <disambig action="add">
      <wd pos="NCMS000" lemma="haiga"/>
    </disambig>
  </rule>
  <rule id="URL" name="url">
    <pattern>
      <token regexp="yes">(https?|ftp)://.*|www.*</token>
    </pattern>
    <disambig action="add">
      <wd pos="IS_URL" lemma="IS_URL"/>
    </disambig>
  </rule>
  <rule id="CREER_CREAR" name="creer/crear">
    <pattern>
      <token inflected="yes" marker="yes">creer</token>
      <token>que</token>
    </pattern>
    <disambig action="remove">
      <wd lemma="crear"/>
    </disambig>
  </rule>
  <rule id="plin" name="a mí, plin">
    <pattern>
      <token>a</token>
      <token regexp="yes">mí|ti|él|ella|nosotros|nosotras|vosotros|vosotras|ellos|ellas|(?-i)\p{Lu}.+</token>
      <token min="0">,</token>
      <token regexp="yes" marker="yes">plin|plim</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="DE_LA_A" name="de la a a la z">
    <pattern>
      <token regexp="yes" case_sensitive="yes">de|a|desde|hasta</token>
      <token case_sensitive="yes">la</token>
      <token regexp="yes" case_sensitive="yes" marker="yes">[a-z]</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="pm_am" name="Ignore spelling pm/am">
    <pattern>
      <token regexp="yes">([012][0-9][\.,])?[0-6]?[0-9]</token>
      <token regexp="yes" case_sensitive="yes">pm|am|PM|AM|GMT|CEST|UTC|EST</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="monedas" name="monedas">
    <pattern>
      <token regexp="yes">M[£€$]</token>
    </pattern>
    <disambig action="add">
      <wd pos="NCMN000" lemma="euros"/>
    </disambig>
  </rule>
  <rule id="plurals" name="algunos plurales">
    <pattern>
      <token postag="D.*" postag_regexp="yes"></token>
      <token regexp="yes" case_sensitive="yes" marker="yes">(Picasso|Miró|Dalí|Rembrandt|Botticelli)s</token>
    </pattern>
    <disambig action="add">
      <wd pos="NCMP000" lemma="np"/>
    </disambig>
  </rule>
  <rule id="ignore_initials" name="ignorar iniciales en nombres propios">
    <pattern>
      <token regexp="yes">\p{Lu}.*</token>
      <token regexp="yes" marker="yes">[A-Z]</token>
      <token spacebefore="no">.</token>
      <token regexp="yes">\p{Lu}.*</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="IGNORE_LETTER_QUOTES" name="ignore letters between quotes">
    <pattern>
      <token postag="_QM_OPEN"></token>
      <token regexp="yes" marker="yes" spacebefore="no">.</token>
      <token postag="_QM_CLOSE"></token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="IGNORE_SPELLING_OF_PUNCTUATION" name="Ignore spelling of punctuation characters">
    <pattern>
      <token regexp="yes">[_~°]+</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="MADE_IN" name="made in">
    <pattern>
      <token marker="yes">made</token>
      <token marker="yes">in</token>
      <token regexp="yes" case_sensitive="yes" marker="yes">USA|China|Europe|Taiwan|Spain|France|Germany|Italy</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="HEXADECIMAL_NOTATION" name="notación hexadecimal">
    <pattern>
      <token regexp="yes" case_sensitive="yes">0x[0-9A-Fa-f]+</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="OCTAL_NOTATION" name="notación octal">
    <pattern>
      <token regexp="yes" case_sensitive="yes">0o[0-7]+</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="ignora_algunas_siglas" name="algunas siglas">
    <pattern>
      <token regexp="yes" case_sensitive="yes">NY|NGC|IgG|Tass|TASS</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
  <rule id="ignore_uppercase_letters" name="A a Z">
    <antipattern>
      <token case_sensitive="yes">y</token>
      <token case_sensitive="yes">Y</token>
    </antipattern>
    <pattern>
      <token regexp="yes" case_sensitive="yes">[A-Z]</token>
      <token regexp="yes" case_sensitive="yes">[aoy]</token>
      <token regexp="yes" case_sensitive="yes">[A-Z]</token>
    </pattern>
    <disambig action="immunize"/>
  </rule>
  <rule id="ABREVIATURAS_CON_PUNTO" name="abreviaturas con punto">
    <pattern>
      <token regexp="yes" case_sensitive="yes" marker="yes">Jr|Inc|[Ee]xt|EXT|Dir|Dr|Dra|Abg|[Aa]cept|[Aa]dm|[Aa]dmón|[Aa]fma|[Aa]fmo|Alfz|Almte|[Aa]p|[Aa]pdo|[Aa]prox|Arq|[Aa]rt|Arz|[Aa]tta|Ayto|[Aa]tte|[Aa]tto|[Aa]v|[Aa]vd|[Aa]vda|Barna|Bco|Bibl|Bma|Bmo|Bo|Brig|Bta|Bto|[Cc]aj|[Cc]ap|Cdad|[Cc]ent|[Cc]f|[Cc]fr|[Cc]go|[Cc]je|[Cc]l|Cmdt|Cmte|Cnel|[Cc]ol|Comod|Comp|Comte|Contralmte|[Cc]oord|[Cc]p|[Cc]rec|[Cc]ta|Cte|[Cc]ts|[Cc]tv|[Cc]tvo|[Cc]ént|Cía|[Cc]ód|[Cc]ónf|[Cc]ónfr|[Dd]cha|[Dd]cho|[Dd]epto|[Dd]iag|[Dd]icc|[Dd]oc|[Dd]pto|[Dd]to|[Dd]updo|[Ee]d|[Ee]dit|[Ee]do|[Ee]f|[Ee]j|Emmo|[Ee]ntlo|[Ee]tc|[Ee]xcl|Excma|Excmo|[Ff]asc|[Ff]ca|Fdo|[Ff]ig|[Ff]ol|Fr|[Ff]ra|[Ff]éc|Gdor|Gdora|Gob|Gral|Hna|Hno|[Ii]b|[Ii]bíd|Il|Ilma|Ilmo|Iltre|[Ii]mp|[Ii]mpr|[Ii]mpto|incl|Ing|Inst|[Ii]zda|[Ii]zdo|[Ii]zq|[Ii]zqda|[Ii]zqdo|Jhs|Lcda|Lcdo|Lda|Ldo|Lic|Ltd|Ltda|Ltdo|Magfca|Magfco|Mons|[Mm]r|[Mm]s|[Mm]áx|[Mm]ín|[Nn]ro|[Nn]úm|Ob|Pat|Pbro|pdo|Pdta|Pdte|[Pp]g|[Pp]l|[Pp]lza|Pnt|[Pp]pal|[Pp]ral|Presb|Prof|[Pp]rov|[Pp]ról|[Pp]za|[Pp]ág|[Pp]árr|Rda|Rdo|[Rr]eg|Rep|Rev|Rte|Rvd|Rvda|Rvdma|Rvdmo|Rvdo|Sdad|Sgto|[Ss]ig|Soc|Sr|Sra|Srs|Sres|Sras|Srta|Sta|Sto|[Tt]el|[Tt]eléf|[Tt]fno|[Tt]rad|Tte|[Tt]ít|Ud|Uds|Univ|Valmte|Vd|Vda|Vdo|Vds|[Vv]id|[Vv]ol|[Vv]s|[Vv]ta|[Vv]to|Xto|[Íí]d</token>
      <token spacebefore="no">.</token>
    </pattern>
    <disambig action="ignore_spelling"/>
  </rule>
</rules>
