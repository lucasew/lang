<?xml version="1.0" encoding="UTF-8"?>
<rules>
  <rulegroup id="ABILITY">
    <rule>
      <pattern lang="en">
        <token>ability</token>
      </pattern>
      <translation lang="fr">aptitude</translation>
    </rule>
    <rule>
      <pattern lang="fr">
        <token>habileté</token>
      </pattern>
      <translation lang="en">skill</translation>
    </rule>
  </rulegroup>
  <rulegroup id="GIFT">
    <rule>
      <pattern lang="en">
        <token>gift</token>
      </pattern>
      <translation lang="de">Geschenk</translation>
    </rule>
    <rule>
      <pattern lang="de">
        <token>Gift</token>
      </pattern>
      <translation lang="en">poison</translation>
    </rule>
  </rulegroup>
  <rulegroup id="ACTUAL">
    <rule>
      <pattern lang="en">
        <token>actual</token>
      </pattern>
      <translation lang="es">real</translation>
    </rule>
    <rule>
      <pattern lang="es">
        <token>actual</token>
      </pattern>
      <translation lang="en">current</translation>
    </rule>
  </rulegroup>

  <rulegroup id="LIBRARY">
    <rule>
      <pattern lang="en">
        <token>library</token>
      </pattern>
      <translation lang="es">biblioteca</translation>
    </rule>
    <rule>
      <pattern lang="es">
        <token>librería</token>
      </pattern>
      <translation lang="en">bookshop</translation>
    </rule>
  </rulegroup>
  <rulegroup id="EVENTUAL">
    <rule>
      <pattern lang="en">
        <token>eventual</token>
      </pattern>
      <translation lang="es">final</translation>
    </rule>
    <rule>
      <pattern lang="es">
        <token>eventual</token>
      </pattern>
      <translation lang="en">temporary</translation>
    </rule>
  </rulegroup>
  <rulegroup id="BECOME">
    <rule>
      <pattern lang="en">
        <token>become</token>
      </pattern>
      <translation lang="de">werden</translation>
    </rule>
    <rule>
      <pattern lang="de">
        <token>bekommen</token>
      </pattern>
      <translation lang="en">get</translation>
    </rule>
  </rulegroup>

  <rulegroup id="EMBARRASSED">
    <rule>
      <pattern lang="en">
        <token>embarrassed</token>
      </pattern>
      <translation lang="es">avergonzado</translation>
    </rule>
    <rule>
      <pattern lang="es">
        <token>embarazada</token>
      </pattern>
      <translation lang="en">pregnant</translation>
    </rule>
  </rulegroup>
  <rulegroup id="PARENTS">
    <rule>
      <pattern lang="en">
        <token>parents</token>
      </pattern>
      <translation lang="fr">parents (père et mère)</translation>
    </rule>
    <rule>
      <pattern lang="fr">
        <token>parents</token>
      </pattern>
      <translation lang="en">relatives</translation>
    </rule>
  </rulegroup>
  <rulegroup id="SYMPATHIC">
    <rule>
      <pattern lang="en">
        <token>sympathetic</token>
      </pattern>
      <translation lang="de">mitfühlend</translation>
    </rule>
    <rule>
      <pattern lang="de">
        <token>sympathisch</token>
      </pattern>
      <translation lang="en">likeable</translation>
    </rule>
  </rulegroup>
  <rulegroup id="FABRIC">
    <rule>
      <pattern lang="en">
        <token>fabric</token>
      </pattern>
      <translation lang="fr">tissu</translation>
    </rule>
    <rule>
      <pattern lang="fr">
        <token>fabrique</token>
      </pattern>
      <translation lang="en">factory</translation>
    </rule>
  </rulegroup>
  <rulegroup id="ARGUMENT">
    <rule>
      <pattern lang="en">
        <token>argument</token>
      </pattern>
      <translation lang="fr">dispute</translation>
    </rule>
    <rule>
      <pattern lang="fr">
        <token>argument</token>
      </pattern>
      <translation lang="en">point / reason</translation>
    </rule>
  </rulegroup>
</rules>
