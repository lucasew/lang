  </category>
  <category id="TYPOGRAPHY" name="Typography">
    <rule id="LT_SOFT_DOUBLE_Q" name="double question">
      <pattern>
        <token>?</token>
        <token>?</token>
      </pattern>
      <message>Often one question mark is enough: "?"</message>
      <short>!!</short>
    </rule>
    <rule id="LT_SOFT_DOUBLE_BANG" name="double bang">
      <pattern>
        <token>!</token>
        <token>!</token>
      </pattern>
      <message>Dažnai pakanka vieno šauktuko: "!"</message>
      <short>!!</short>
    </rule>
  </category>
</rules>
