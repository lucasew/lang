<?xml version="1.0" encoding="UTF-8"?>
<!-- Soft ZH optional rules: default off until -e or SOFT_OPTIONAL. Space-tokenized. -->
<rules lang="zh">
  <category id="STYLE" name="Style">
    <rule id="ZH_SOFT_OPT_ZAI_FANGMIAN" name="在方面 soft optional" default="off">
      <pattern>
        <token>在</token>
        <token>方面</token>
      </pattern>
      <message>可考虑更直接的表述。</message>
      <short>style</short>
    </rule>
    <rule id="ZH_SOFT_OPT_JIU_ER_YAN" name="就而言 soft optional" default="off">
      <pattern>
        <token>就</token>
        <token>而言</token>
      </pattern>
      <message>可考虑「关于」或更简洁的说法。</message>
      <short>style</short>
    </rule>
    <rule id="ZH_SOFT_OPT_WEILE" name="为了 soft optional" default="off">
      <pattern>
        <token>为了</token>
      </pattern>
      <message>在口语外可考虑更简洁的目的表达。</message>
      <short>style</short>
    </rule>
  </category>
</rules>
