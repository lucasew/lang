<?xml version="1.0" encoding="UTF-8"?>
<rules lang="sv">
  <category id="GRAMMAR" name="Grammar">
    <rule id="SV_SOFT_DE_DOM" name="de/dom">
      <pattern>
        <token>dom</token>
        <token>är</token>
      </pattern>
      <message>Menade du "de är"?</message>
      <short>de/dom</short>
    </rule>
    <rule id="SV_SOFT_DOM_VAR" name="dom var">
      <pattern>
        <token>dom</token>
        <token>var</token>
      </pattern>
      <message>Menade du "de var"?</message>
      <short>de/dom</short>
    </rule>
    <rule id="SV_SOFT_OCH_OCH" name="och och">
      <pattern>
        <token>och</token>
        <token>och</token>
      </pattern>
      <message>Möjlig upprepning av "och".</message>
      <short>och och</short>
    </rule>
    <rule id="SV_SOFT_VARAN" name="varan">
      <pattern>
        <token>en</token>
        <token>varan</token>
      </pattern>
      <message>Menade du "en vara"?</message>
      <short>varan</short>
    </rule>
    <rule id="SV_SOFT_DOM_HAR" name="dom har">
      <pattern>
        <token>dom</token>
        <token>har</token>
      </pattern>
      <message>Menade du "de har"?</message>
      <short>de/dom</short>
    </rule>
    <rule id="SV_SOFT_STORRE_AN" name="större än">
      <pattern>
        <token>större</token>
        <token>som</token>
      </pattern>
      <message>Menade du "större än"?</message>
      <short>än/som</short>
    </rule>
    <rule id="SV_SOFT_MEDANS" name="medans">
      <pattern>
        <token>medans</token>
      </pattern>
      <message>Menade du "medan"?</message>
      <short>medans</short>
    </rule>
    <rule id="SV_SOFT_DOM_SKA" name="dom ska">
      <pattern>
        <token>dom</token>
        <token>ska</token>
      </pattern>
      <message>Menade du "de ska"?</message>
      <short>de/dom</short>
    </rule>
    <rule id="SV_SOFT_DOM_KAN" name="dom kan">
      <pattern>
        <token>dom</token>
        <token>kan</token>
      </pattern>
      <message>Menade du "de kan"?</message>
      <short>de/dom</short>
    </rule>
  </category>
  <category id="TYPOGRAPHY" name="Typografi">
    <rule id="SV_SOFT_DOUBLE_BANG" name="dubbelt utropstecken">
      <pattern>
        <token>!</token>
        <token>!</token>
      </pattern>
      <message>Ett utropstecken räcker ofta: "!"</message>
      <short>interpunktion</short>
    </rule>
  </category>
</rules>
