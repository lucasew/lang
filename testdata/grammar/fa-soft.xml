        <token>که</token>
        <token>که</token>
      </pattern>
      <message>تکرار احتمالی «که».</message>
      <short>که که</short>
    </rule>
  </category>
  <category id="TYPOGRAPHY" name="Typography">
    <rule id="FA_SOFT_DOUBLE_BANG" name="double bang">
      <pattern>
        <token>!</token>
        <token>!</token>
      </pattern>
      <message>اغلب یک علامت تعجب کافی است: "!"</message>
      <short>!!</short>
    </rule>
  </category>
</rules>
