<?xml version="1.0" encoding="UTF-8"?>
<rules lang="fa">
  <category id="GRAMMAR" name="Grammar">
    <rule id="FA_SOFT_VA_VA" name="و و">
      <pattern>
        <token>و</token>
        <token>و</token>
      </pattern>
      <message>تکرار احتمالی «و».</message>
      <short>و و</short>
    </rule>
    <rule id="FA_SOFT_DAR_DAR" name="در در">
      <pattern>
        <token>در</token>
        <token>در</token>
      </pattern>
      <message>تکرار احتمالی «در».</message>
      <short>در در</short>
    </rule>
    <rule id="FA_SOFT_AZ_AZ" name="از از">
      <pattern>
        <token>از</token>
        <token>از</token>
      </pattern>
      <message>تکرار احتمالی «از».</message>
      <short>از از</short>
    </rule>
    <rule id="FA_SOFT_BE_BE" name="به به">
      <pattern>
        <token>به</token>
        <token>به</token>
      </pattern>
      <message>تکرار احتمالی «به».</message>
      <short>به به</short>
    </rule>
    <rule id="FA_SOFT_RA_RA" name="را را">
