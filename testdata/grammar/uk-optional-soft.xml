<?xml version="1.0" encoding="UTF-8"?>
<!-- Soft UK optional rules: default off until -e or SOFT_OPTIONAL. -->
<rules lang="uk">
  <category id="STYLE" name="Style">
    <rule id="UK_SOFT_OPT_V_RAMKAH" name="в рамках soft optional" default="off">
      <pattern>
        <token>в</token>
        <token>рамках</token>
      </pattern>
      <message>Розгляньте «у» або «під час».</message>
      <short>style</short>
    </rule>
    <rule id="UK_SOFT_OPT_Z_METOYU" name="з метою soft optional" default="off">
      <pattern>
        <token>з</token>
        <token>метою</token>
      </pattern>
      <message>Розгляньте «щоб».</message>
      <short>style</short>
    </rule>
    <rule id="UK_SOFT_OPT_U_ZV_YAZKU" name="у зв'язку з soft optional" default="off">
      <pattern>
        <token>у</token>
        <token>зв'язку</token>
        <token>з</token>
      </pattern>
      <message>Розгляньте «через» або «тому що».</message>
      <short>style</short>
    </rule>
  </category>
</rules>
