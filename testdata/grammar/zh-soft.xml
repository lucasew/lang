      </pattern>
      <message>可能重复了 "有"。</message>
      <short>有 有</short>
    </rule>
  </category>
  <category id="TYPOGRAPHY" name="Typography">
    <rule id="ZH_SOFT_DOUBLE_Q" name="double question">
      <pattern>
        <token>?</token>
        <token>?</token>
      </pattern>
      <message>通常一个问号即可："?"</message>
      <short>!!</short>
    </rule>
    <rule id="ZH_SOFT_DOUBLE_BANG" name="double bang">
      <pattern>
        <token>!</token>
        <token>!</token>
      </pattern>
      <message>通常一个感叹号即可："!"</message>
      <short>!!</short>
    </rule>
  </category>
</rules>
