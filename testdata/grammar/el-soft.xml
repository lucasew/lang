        <token>να</token>
        <token>να</token>
      </pattern>
      <message>Πιθανή επανάληψη του "να".</message>
      <short>να να</short>
    </rule>
    <rule id="EL_SOFT_SE_SE" name="σε σε">
      <pattern>
        <token>σε</token>
        <token>σε</token>
      </pattern>
      <message>Πιθανή επανάληψη του "σε".</message>
      <short>σε σε</short>
    </rule>
  </category>
</rules>
