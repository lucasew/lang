<?xml version="1.0" encoding="UTF-8"?>
<rules lang="en">
  <category id="GRAMMAR" name="Grammar">
    <rule id="EN_SOFT_YOUR_YOU_RE" name="your/you're">
      <pattern>
        <token>your</token>
        <token>welcome</token>
      </pattern>
      <message>Did you mean "you're welcome"?</message>
      <short>your/you're</short>
    </rule>
    <rule id="EN_SOFT_ITS_IT_S" name="its/it's">
      <pattern>
        <token>its</token>
        <token>a</token>
      </pattern>
      <message>Did you mean "it's a"?</message>
      <short>its/it's</short>
    </rule>
    <rule id="EN_SOFT_THEIR_THEY_RE" name="their/they're">
      <pattern>
        <token>their</token>
        <token>going</token>
      </pattern>
      <message>Did you mean "they're going"?</message>
      <short>their/they're</short>
    </rule>
    <rule id="EN_SOFT_THEN_THAN" name="then/than">
      <pattern>
        <token>better</token>
        <token>then</token>
      </pattern>
      <message>Did you mean "better than"?</message>
      <short>then/than</short>
    </rule>
    <rule id="EN_SOFT_CAN_CAN" name="can can">
      <pattern>
        <token>can</token>
        <token>can</token>
      </pattern>
      <message>Possible accidental repetition of "can".</message>
      <short>can can</short>
    </rule>
    <rule id="EN_SOFT_THAT_THAT" name="that that">
      <pattern>
        <token>that</token>
        <token>that</token>
      </pattern>
      <message>Possible accidental repetition of "that".</message>
      <short>that that</short>
    </rule>
    <rule id="EN_SOFT_HAD_OF" name="had of">
      <pattern>
        <token>had</token>
        <token>of</token>
      </pattern>
      <message>Did you mean "had"?</message>
      <short>had of</short>
    </rule>
    <!-- Soft agreement: surface + POS where tagger is reliable -->
    <rule id="EN_SOFT_THEY_IS" name="they/we is">
      <pattern>
        <token regexp="yes">They|We|they|we</token>
        <token>is</token>
      </pattern>
      <message>Did you mean "are"?</message>
      <short>agreement</short>
    </rule>
    <rule id="EN_SOFT_I_ARE" name="I are">
      <pattern>
        <token regexp="yes">I</token>
        <token>are</token>
      </pattern>
      <message>Did you mean "am"?</message>
      <short>agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_ARE" name="he/she/it are">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>are</token>
      </pattern>
      <message>Did you mean "is"?</message>
      <short>agreement</short>
    </rule>
    <rule id="EN_SOFT_THIS_ARE" name="this/that are">
      <pattern>
        <token regexp="yes">This|That|this|that</token>
        <token postag="VBP">are</token>
      </pattern>
      <message>Did you mean "is"?</message>
      <short>agreement</short>
    </rule>
    <rule id="EN_SOFT_A_PLURAL" name="a + plural noun">
      <pattern>
        <token regexp="yes">[Aa]</token>
        <token postag="NNS"/>
      </pattern>
      <message>The article "a" usually does not precede a plural noun.</message>
      <short>a + plural</short>
    </rule>
    <!-- Soft 3sg: subject pronoun + bare present (common learner errors) -->
    <rule id="EN_SOFT_HE_GO" name="he/she/it go">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>go</token>
      </pattern>
      <message>Did you mean "goes"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_WALK" name="he/she/it walk">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>walk</token>
      </pattern>
      <message>Did you mean "walks"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_LIKE" name="he/she/it like">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>like</token>
      </pattern>
      <message>Did you mean "likes"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_WANT" name="he/she/it want">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>want</token>
      </pattern>
      <message>Did you mean "wants"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_NEED" name="he/she/it need">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>need</token>
      </pattern>
      <message>Did you mean "needs"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_LOOSE_LOSE" name="loose/lose">
      <pattern>
        <token>loose</token>
        <token>weight</token>
      </pattern>
      <message>Did you mean "lose weight"?</message>
      <short>loose/lose</short>
    </rule>
    <rule id="EN_SOFT_AFFECT_EFFECT" name="affect/effect">
      <pattern>
        <token>an</token>
        <token>affect</token>
      </pattern>
      <message>Did you mean "an effect"?</message>
      <short>affect/effect</short>
    </rule>
    <rule id="EN_SOFT_TAKE_AFFECT" name="take affect">
      <pattern>
        <token>take</token>
        <token>affect</token>
      </pattern>
      <message>Did you mean "take effect"?</message>
      <short>affect/effect</short>
    </rule>
    <rule id="EN_SOFT_QUITE_QUIET" name="quite/quiet">
      <pattern>
        <token>be</token>
        <token>quite</token>
      </pattern>
      <message>Did you mean "be quiet"?</message>
      <short>quite/quiet</short>
    </rule>
    <rule id="EN_SOFT_YOUR_WELCOME" name="your welcome (variant)">
      <pattern>
        <token regexp="yes">Your|YOUR</token>
        <token regexp="yes">Welcome|WELCOME</token>
      </pattern>
      <message>Did you mean "You're welcome"?</message>
      <short>your/you're</short>
    </rule>
    <rule id="EN_SOFT_PEAKED_INTEREST" name="peaked my interest">
      <pattern>
        <token>peaked</token>
        <token>my</token>
        <token>interest</token>
      </pattern>
      <message>Did you mean "piqued my interest"?</message>
      <short>peak/pique</short>
    </rule>
    <rule id="EN_SOFT_COULD_CARE_LESS" name="could care less">
      <pattern>
        <token>could</token>
        <token>care</token>
        <token>less</token>
      </pattern>
      <message>Did you mean "couldn't care less"?</message>
      <short>idiom</short>
    </rule>
    <rule id="EN_SOFT_WHOSE_WHO_S" name="whose/who's">
      <pattern>
        <token>whose</token>
        <token>going</token>
      </pattern>
      <message>Did you mean "who's going"?</message>
      <short>whose/who's</short>
    </rule>
    <rule id="EN_SOFT_WHO_S_BOOK" name="who's book">
      <pattern>
        <token regexp="yes">Who|who</token>
        <token>'</token>
        <token>s</token>
        <token>book</token>
      </pattern>
      <message>Did you mean "whose book"?</message>
      <short>whose/who's</short>
    </rule>
    <rule id="EN_SOFT_BREATH_BREATHE" name="breath/breathe">
      <pattern>
        <token>breath</token>
        <token>deeply</token>
      </pattern>
      <message>Did you mean "breathe deeply"?</message>
      <short>breath/breathe</short>
    </rule>
    <rule id="EN_SOFT_ADVICE_ADVISE" name="advice/advise">
      <pattern>
        <token>to</token>
        <token>advice</token>
      </pattern>
      <message>Did you mean "to advise"?</message>
      <short>advice/advise</short>
    </rule>
    <rule id="EN_SOFT_PRACTICE_PRACTISE" name="practice verb (US soft)">
      <pattern>
        <token>to</token>
        <token>practise</token>
      </pattern>
      <message>In American English, prefer "to practice".</message>
      <short>practise/practice</short>
    </rule>
    <rule id="EN_SOFT_HE_DO" name="he/she/it do">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>do</token>
      </pattern>
      <message>Did you mean "does"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_HAVE" name="he/she/it have">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>have</token>
      </pattern>
      <message>Did you mean "has"?</message>
      <short>3sg agreement</short>
    </rule>
    <!-- Soft dialect / nonstandard past forms -->
    <rule id="EN_SOFT_I_SEEN" name="I seen">
      <pattern>
        <token regexp="yes">I</token>
        <token>seen</token>
      </pattern>
      <message>Did you mean "I saw" or "I have seen"?</message>
      <short>past form</short>
    </rule>
    <rule id="EN_SOFT_I_DONE" name="I done">
      <pattern>
        <token regexp="yes">I</token>
        <token>done</token>
      </pattern>
      <message>Did you mean "I did" or "I have done"?</message>
      <short>past form</short>
    </rule>
    <rule id="EN_SOFT_WE_WAS" name="we/you/they was">
      <pattern>
        <token regexp="yes">We|You|They|we|you|they</token>
        <token>was</token>
      </pattern>
      <message>Did you mean "were"?</message>
      <short>agreement</short>
    </rule>
    <rule id="EN_SOFT_I_IS" name="I is">
      <pattern>
        <token regexp="yes">I</token>
        <token>is</token>
      </pattern>
      <message>Did you mean "am"?</message>
      <short>agreement</short>
    </rule>
    <rule id="EN_SOFT_ME_AND" name="me and X went">
      <pattern>
        <token>Me</token>
        <token>and</token>
      </pattern>
      <message>In subject position, prefer "I and …" or "… and I".</message>
      <short>case</short>
    </rule>
    <rule id="EN_SOFT_SHOULD_OF_SPACED" name="should of (soft XML)">
      <pattern>
        <token>should</token>
        <token>of</token>
        <token>been</token>
      </pattern>
      <message>Did you mean "should have been"?</message>
      <short>should of</short>
    </rule>
    <rule id="EN_SOFT_SUPPOSE_TO" name="suppose to">
      <pattern>
        <token>suppose</token>
        <token>to</token>
      </pattern>
      <message>Did you mean "supposed to"?</message>
      <short>suppose to</short>
    </rule>
    <!-- Surface forms that exist in the dict but usually want apostrophes -->
    <rule id="EN_SOFT_CANT" name="cant → can't">
      <pattern>
        <token regexp="yes">cant|Cant</token>
      </pattern>
      <message>Did you mean "can't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_WONT" name="wont → won't">
      <pattern>
        <token regexp="yes">wont|Wont</token>
      </pattern>
      <message>Did you mean "won't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_DONT" name="dont → don't">
      <pattern>
        <token regexp="yes">dont|Dont</token>
      </pattern>
      <message>Did you mean "don't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_DIDNT" name="didnt → didn't">
      <pattern>
        <token regexp="yes">didnt|Didnt</token>
      </pattern>
      <message>Did you mean "didn't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_ISNT" name="isnt → isn't">
      <pattern>
        <token regexp="yes">isnt|Isnt</token>
      </pattern>
      <message>Did you mean "isn't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_ARENT" name="arent → aren't">
      <pattern>
        <token regexp="yes">arent|Arent</token>
      </pattern>
      <message>Did you mean "aren't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_WASNT" name="wasnt → wasn't">
      <pattern>
        <token regexp="yes">wasnt|Wasnt</token>
      </pattern>
      <message>Did you mean "wasn't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_WERENT" name="werent → weren't">
      <pattern>
        <token regexp="yes">werent|Werent</token>
      </pattern>
      <message>Did you mean "weren't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_HASNT" name="hasnt → hasn't">
      <pattern>
        <token regexp="yes">hasnt|Hasnt</token>
      </pattern>
      <message>Did you mean "hasn't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_HAVENT" name="havent → haven't">
      <pattern>
        <token regexp="yes">havent|Havent</token>
      </pattern>
      <message>Did you mean "haven't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_WOULDNT" name="wouldnt → wouldn't">
      <pattern>
        <token regexp="yes">wouldnt|Wouldnt</token>
      </pattern>
      <message>Did you mean "wouldn't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_SHOULDNT" name="shouldnt → shouldn't">
      <pattern>
        <token regexp="yes">shouldnt|Shouldnt</token>
      </pattern>
      <message>Did you mean "shouldn't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_COULDNT" name="couldnt → couldn't">
      <pattern>
        <token regexp="yes">couldnt|Couldnt</token>
      </pattern>
      <message>Did you mean "couldn't"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_YOURE" name="youre → you're">
      <pattern>
        <token regexp="yes">youre|Youre</token>
      </pattern>
      <message>Did you mean "you're"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_THEYRE" name="theyre → they're">
      <pattern>
        <token regexp="yes">theyre|Theyre</token>
      </pattern>
      <message>Did you mean "they're"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_WERE_WE_RE" name="were → we're (soft context)">
      <pattern>
        <token regexp="yes">Were|were</token>
        <token>going</token>
        <token>to</token>
      </pattern>
      <message>Did you mean "we're going to"?</message>
      <short>were/we're</short>
    </rule>
    <rule id="EN_SOFT_ALOT" name="alot">
      <pattern>
        <token regexp="yes">alot|Alot</token>
      </pattern>
      <message>Did you mean "a lot"?</message>
      <short>alot</short>
    </rule>
    <rule id="EN_SOFT_INFACT" name="infact">
      <pattern>
        <token regexp="yes">infact|Infact</token>
      </pattern>
      <message>Did you mean "in fact"?</message>
      <short>infact</short>
    </rule>
    <rule id="EN_SOFT_ASWELL" name="aswell">
      <pattern>
        <token regexp="yes">aswell|Aswell</token>
      </pattern>
      <message>Did you mean "as well"?</message>
      <short>aswell</short>
    </rule>
    <rule id="EN_SOFT_NEVERTHELESS_SPLIT" name="never the less already phrase">
      <pattern>
        <token>never</token>
        <token>the</token>
        <token>less</token>
      </pattern>
      <message>Did you mean "nevertheless"?</message>
      <short>nevertheless</short>
    </rule>
    <rule id="EN_SOFT_EVERYTIME" name="everytime">
      <pattern>
        <token regexp="yes">everytime|Everytime</token>
      </pattern>
      <message>Did you mean "every time"?</message>
      <short>everytime</short>
    </rule>
    <rule id="EN_SOFT_NOONE" name="noone">
      <pattern>
        <token regexp="yes">noone|Noone</token>
      </pattern>
      <message>Did you mean "no one"?</message>
      <short>noone</short>
    </rule>
    <rule id="EN_SOFT_ANYMORE_SPLIT" name="any more vs anymore soft">
      <pattern>
        <token>not</token>
        <token>any</token>
        <token>more</token>
        <token>books</token>
      </pattern>
      <message>For quantity, "any more" (two words) is preferred in some guides.</message>
      <short>anymore</short>
    </rule>
    <rule id="EN_SOFT_INTO_IN_TO" name="into vs in to">
      <pattern>
        <token>give</token>
        <token>into</token>
      </pattern>
      <message>Did you mean "give in to"?</message>
      <short>into</short>
    </rule>
    <rule id="EN_SOFT_EACHOTHER" name="eachother soft xml">
      <pattern>
        <token regexp="yes">eachother|Eachother</token>
      </pattern>
      <message>Did you mean "each other"?</message>
      <short>eachother</short>
    </rule>
    <rule id="EN_SOFT_INSPITE" name="inspite">
      <pattern>
        <token regexp="yes">inspite|Inspite</token>
      </pattern>
      <message>Did you mean "in spite"?</message>
      <short>inspite</short>
    </rule>
    <rule id="EN_SOFT_ATLEAST" name="atleast">
      <pattern>
        <token regexp="yes">atleast|Atleast</token>
      </pattern>
      <message>Did you mean "at least"?</message>
      <short>atleast</short>
    </rule>
    <rule id="EN_SOFT_INCASE" name="incase">
      <pattern>
        <token regexp="yes">incase|Incase</token>
      </pattern>
      <message>Did you mean "in case"?</message>
      <short>incase</short>
    </rule>
    <rule id="EN_SOFT_UPTO" name="upto">
      <pattern>
        <token regexp="yes">upto|Upto</token>
      </pattern>
      <message>Did you mean "up to"?</message>
      <short>upto</short>
    </rule>
    <rule id="EN_SOFT_WORKOUT_VERB" name="workout as verb">
      <pattern>
        <token>to</token>
        <token>workout</token>
      </pattern>
      <message>Did you mean "to work out"?</message>
      <short>workout</short>
    </rule>
    <rule id="EN_SOFT_SETUP_VERB" name="setup as verb">
      <pattern>
        <token>to</token>
        <token>setup</token>
      </pattern>
      <message>Did you mean "to set up"?</message>
      <short>setup</short>
    </rule>
    <rule id="EN_SOFT_LOGIN_VERB" name="login as verb">
      <pattern>
        <token>to</token>
        <token>login</token>
      </pattern>
      <message>Did you mean "to log in"?</message>
      <short>login</short>
    </rule>
    <rule id="EN_SOFT_CHECKOUT_VERB" name="checkout as verb">
      <pattern>
        <token>to</token>
        <token>checkout</token>
      </pattern>
      <message>Did you mean "to check out"?</message>
      <short>checkout</short>
    </rule>
    <rule id="EN_SOFT_BACKUP_VERB" name="backup as verb">
      <pattern>
        <token>to</token>
        <token>backup</token>
      </pattern>
      <message>Did you mean "to back up"?</message>
      <short>backup</short>
    </rule>
    <rule id="EN_SOFT_WOULDVE" name="wouldve">
      <pattern>
        <token regexp="yes">wouldve|Wouldve|wouldve</token>
      </pattern>
      <message>Did you mean "would've"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_COULDVE" name="couldve">
      <pattern>
        <token regexp="yes">couldve|Couldve</token>
      </pattern>
      <message>Did you mean "could've"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_SHOULDVE" name="shouldve">
      <pattern>
        <token regexp="yes">shouldve|Shouldve</token>
      </pattern>
      <message>Did you mean "should've"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_MUSTVE" name="mustve">
      <pattern>
        <token regexp="yes">mustve|Mustve</token>
      </pattern>
      <message>Did you mean "must've"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_MIGHTVE" name="mightve">
      <pattern>
        <token regexp="yes">mightve|Mightve</token>
      </pattern>
      <message>Did you mean "might've"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_THATLL" name="thatll">
      <pattern>
        <token regexp="yes">thatll|Thatll</token>
      </pattern>
      <message>Did you mean "that'll"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_ITLL" name="itll">
      <pattern>
        <token regexp="yes">itll|Itll</token>
      </pattern>
      <message>Did you mean "it'll"?</message>
      <short>contraction</short>
    </rule>
    <rule id="EN_SOFT_BETWEEN_YOU_AND_I" name="between you and I">
      <pattern>
        <token>between</token>
        <token>you</token>
        <token>and</token>
        <token>I</token>
      </pattern>
      <message>Did you mean "between you and me"?</message>
      <short>case</short>
    </rule>
    <rule id="EN_SOFT_FOR_YOU_AND_I" name="for you and I">
      <pattern>
        <token>for</token>
        <token>you</token>
        <token>and</token>
        <token>I</token>
      </pattern>
      <message>Did you mean "for you and me"?</message>
      <short>case</short>
    </rule>
    <rule id="EN_SOFT_WITH_YOU_AND_I" name="with you and I">
      <pattern>
        <token>with</token>
        <token>you</token>
        <token>and</token>
        <token>I</token>
      </pattern>
      <message>Did you mean "with you and me"?</message>
      <short>case</short>
    </rule>
    <rule id="EN_SOFT_TO_WHO" name="to who">
      <pattern>
        <token>to</token>
        <token>who</token>
      </pattern>
      <message>Did you mean "to whom"?</message>
      <short>who/whom</short>
    </rule>
    <rule id="EN_SOFT_LESS_PEOPLE" name="less people">
      <pattern>
        <token>less</token>
        <token>people</token>
      </pattern>
      <message>Did you mean "fewer people"?</message>
      <short>less/fewer</short>
    </rule>
    <rule id="EN_SOFT_AMOUNT_OF_PEOPLE" name="amount of people">
      <pattern>
        <token>amount</token>
        <token>of</token>
        <token>people</token>
      </pattern>
      <message>Did you mean "number of people"?</message>
      <short>amount/number</short>
    </rule>
    <rule id="EN_SOFT_THESE_ONES" name="these ones">
      <pattern>
        <token>these</token>
        <token>ones</token>
      </pattern>
      <message>Consider "these" alone.</message>
