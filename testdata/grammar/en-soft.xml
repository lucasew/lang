<?xml version="1.0" encoding="UTF-8"?>
<rules lang="en">
  <category id="GRAMMAR" name="Grammar">
    <rule id="EN_SOFT_YOUR_YOU_RE" name="your/you're">
      <pattern>
        <token>your</token>
        <token>welcome</token>
      </pattern>
      <message>Did you mean "you're welcome"?</message>
      <short>your/you're</short>
    </rule>
    <rule id="EN_SOFT_ITS_IT_S" name="its/it's">
      <pattern>
        <token>its</token>
        <token>a</token>
      </pattern>
      <message>Did you mean "it's a"?</message>
      <short>its/it's</short>
    </rule>
    <rule id="EN_SOFT_THEIR_THEY_RE" name="their/they're">
      <pattern>
        <token>their</token>
        <token>going</token>
      </pattern>
      <message>Did you mean "they're going"?</message>
      <short>their/they're</short>
    </rule>
    <rule id="EN_SOFT_THEN_THAN" name="then/than">
      <pattern>
        <token>better</token>
        <token>then</token>
      </pattern>
      <message>Did you mean "better than"?</message>
      <short>then/than</short>
    </rule>
    <rule id="EN_SOFT_CAN_CAN" name="can can">
      <pattern>
        <token>can</token>
        <token>can</token>
      </pattern>
      <message>Possible accidental repetition of "can".</message>
      <short>can can</short>
    </rule>
    <rule id="EN_SOFT_THAT_THAT" name="that that">
      <pattern>
        <token>that</token>
        <token>that</token>
      </pattern>
      <message>Possible accidental repetition of "that".</message>
      <short>that that</short>
    </rule>
    <rule id="EN_SOFT_HAD_OF" name="had of">
      <pattern>
        <token>had</token>
        <token>of</token>
      </pattern>
      <message>Did you mean "had"?</message>
      <short>had of</short>
    </rule>
    <!-- Soft agreement: surface + POS where tagger is reliable -->
    <rule id="EN_SOFT_THEY_IS" name="they/we is">
      <pattern>
        <token regexp="yes">They|We|they|we</token>
        <token>is</token>
      </pattern>
      <message>Did you mean "are"?</message>
      <short>agreement</short>
    </rule>
    <rule id="EN_SOFT_I_ARE" name="I are">
      <pattern>
        <token regexp="yes">I</token>
        <token>are</token>
      </pattern>
      <message>Did you mean "am"?</message>
      <short>agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_ARE" name="he/she/it are">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>are</token>
      </pattern>
      <message>Did you mean "is"?</message>
      <short>agreement</short>
    </rule>
    <rule id="EN_SOFT_THIS_ARE" name="this/that are">
      <pattern>
        <token regexp="yes">This|That|this|that</token>
        <token postag="VBP">are</token>
      </pattern>
      <message>Did you mean "is"?</message>
      <short>agreement</short>
    </rule>
    <rule id="EN_SOFT_A_PLURAL" name="a + plural noun">
      <pattern>
        <token regexp="yes">[Aa]</token>
        <token postag="NNS"/>
      </pattern>
      <message>The article "a" usually does not precede a plural noun.</message>
      <short>a + plural</short>
    </rule>
    <!-- Soft 3sg: subject pronoun + bare present (common learner errors) -->
    <rule id="EN_SOFT_HE_GO" name="he/she/it go">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>go</token>
      </pattern>
      <message>Did you mean "goes"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_WALK" name="he/she/it walk">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>walk</token>
      </pattern>
      <message>Did you mean "walks"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_LIKE" name="he/she/it like">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>like</token>
      </pattern>
      <message>Did you mean "likes"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_WANT" name="he/she/it want">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>want</token>
      </pattern>
      <message>Did you mean "wants"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_NEED" name="he/she/it need">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>need</token>
      </pattern>
      <message>Did you mean "needs"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_LOOSE_LOSE" name="loose/lose">
      <pattern>
        <token>loose</token>
        <token>weight</token>
      </pattern>
      <message>Did you mean "lose weight"?</message>
      <short>loose/lose</short>
    </rule>
    <rule id="EN_SOFT_AFFECT_EFFECT" name="affect/effect">
      <pattern>
        <token>an</token>
        <token>affect</token>
      </pattern>
      <message>Did you mean "an effect"?</message>
      <short>affect/effect</short>
    </rule>
    <rule id="EN_SOFT_TAKE_AFFECT" name="take affect">
      <pattern>
        <token>take</token>
        <token>affect</token>
      </pattern>
      <message>Did you mean "take effect"?</message>
      <short>affect/effect</short>
    </rule>
    <rule id="EN_SOFT_QUITE_QUIET" name="quite/quiet">
      <pattern>
        <token>be</token>
        <token>quite</token>
      </pattern>
      <message>Did you mean "be quiet"?</message>
      <short>quite/quiet</short>
    </rule>
    <rule id="EN_SOFT_YOUR_WELCOME" name="your welcome (variant)">
      <pattern>
        <token regexp="yes">Your|YOUR</token>
        <token regexp="yes">Welcome|WELCOME</token>
      </pattern>
      <message>Did you mean "You're welcome"?</message>
      <short>your/you're</short>
    </rule>
    <rule id="EN_SOFT_PEAKED_INTEREST" name="peaked my interest">
      <pattern>
        <token>peaked</token>
        <token>my</token>
        <token>interest</token>
      </pattern>
      <message>Did you mean "piqued my interest"?</message>
      <short>peak/pique</short>
    </rule>
    <rule id="EN_SOFT_COULD_CARE_LESS" name="could care less">
      <pattern>
        <token>could</token>
        <token>care</token>
        <token>less</token>
      </pattern>
      <message>Did you mean "couldn't care less"?</message>
      <short>idiom</short>
    </rule>
    <rule id="EN_SOFT_WHOSE_WHO_S" name="whose/who's">
      <pattern>
        <token>whose</token>
        <token>going</token>
      </pattern>
      <message>Did you mean "who's going"?</message>
      <short>whose/who's</short>
    </rule>
    <rule id="EN_SOFT_WHO_S_BOOK" name="who's book">
      <pattern>
        <token regexp="yes">Who|who</token>
        <token>'</token>
        <token>s</token>
        <token>book</token>
      </pattern>
      <message>Did you mean "whose book"?</message>
      <short>whose/who's</short>
    </rule>
    <rule id="EN_SOFT_BREATH_BREATHE" name="breath/breathe">
      <pattern>
        <token>breath</token>
        <token>deeply</token>
      </pattern>
      <message>Did you mean "breathe deeply"?</message>
      <short>breath/breathe</short>
    </rule>
    <rule id="EN_SOFT_ADVICE_ADVISE" name="advice/advise">
      <pattern>
        <token>to</token>
        <token>advice</token>
      </pattern>
      <message>Did you mean "to advise"?</message>
      <short>advice/advise</short>
    </rule>
    <rule id="EN_SOFT_PRACTICE_PRACTISE" name="practice verb (US soft)">
      <pattern>
        <token>to</token>
        <token>practise</token>
      </pattern>
      <message>In American English, prefer "to practice".</message>
      <short>practise/practice</short>
    </rule>
    <rule id="EN_SOFT_HE_DO" name="he/she/it do">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>do</token>
      </pattern>
      <message>Did you mean "does"?</message>
      <short>3sg agreement</short>
    </rule>
    <rule id="EN_SOFT_HE_HAVE" name="he/she/it have">
      <pattern>
        <token regexp="yes">He|She|It|he|she|it</token>
        <token>have</token>
      </pattern>
      <message>Did you mean "has"?</message>
      <short>3sg agreement</short>
    </rule>
  </category>
</rules>
