<?xml version="1.0" encoding="UTF-8"?>
<!-- Soft FA optional rules: default off until -e or SOFT_OPTIONAL. -->
<rules lang="fa">
  <category id="STYLE" name="Style">
    <rule id="FA_SOFT_OPT_DAR_RASTAYE" name="در راستای soft optional" default="off">
      <pattern>
        <token>در</token>
        <token>راستای</token>
      </pattern>
      <message>«برای» یا «به‌منظور» را در نظر بگیرید.</message>
      <short>style</short>
    </rule>
    <rule id="FA_SOFT_OPT_BE_MANZOOR" name="به منظور soft optional" default="off">
      <pattern>
        <token>به</token>
        <token>منظور</token>
      </pattern>
      <message>در صورت امکان «برای» را در نظر بگیرید.</message>
      <short>style</short>
    </rule>
    <rule id="FA_SOFT_OPT_DAR_RABETE" name="در رابطه با soft optional" default="off">
      <pattern>
        <token>در</token>
        <token>رابطه</token>
        <token>با</token>
      </pattern>
      <message>«درباره» یا «راجع به» را در نظر بگیرید.</message>
      <short>style</short>
    </rule>
  </category>
</rules>
