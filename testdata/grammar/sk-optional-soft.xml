<?xml version="1.0" encoding="UTF-8"?>
<!-- Soft SK optional rules: default off until -e or SOFT_OPTIONAL. -->
<rules lang="sk">
  <category id="STYLE" name="Style">
    <rule id="SK_SOFT_OPT_V_RAMCI" name="v rámci soft optional" default="off">
      <pattern>
        <token>v</token>
        <token>rámci</token>
      </pattern>
      <message>Zvážte "pri" alebo "počas".</message>
      <short>style</short>
    </rule>
    <rule id="SK_SOFT_OPT_ZA_UCEL" name="za účelom soft optional" default="off">
      <pattern>
        <token>za</token>
        <token>účelom</token>
      </pattern>
      <message>Zvážte "aby" alebo "pre".</message>
      <short>style</short>
    </rule>
    <rule id="SK_SOFT_OPT_V_SUVISLOSTI" name="v súvislosti s soft optional" default="off">
      <pattern>
        <token>v</token>
        <token>súvislosti</token>
        <token>s</token>
      </pattern>
      <message>Zvážte "kvôli" alebo "o".</message>
      <short>style</short>
    </rule>
  </category>
</rules>
