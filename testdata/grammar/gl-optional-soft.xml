<?xml version="1.0" encoding="UTF-8"?>
<!-- Soft GL optional rules: default off until -e or SOFT_OPTIONAL. -->
<rules lang="gl">
  <category id="STYLE" name="Style">
    <rule id="GL_SOFT_OPT_NO_MARCO" name="no marco soft optional" default="off">
      <pattern>
        <token>no</token>
        <token>marco</token>
      </pattern>
      <message>Considere "en" ou "durante".</message>
      <short>style</short>
    </rule>
    <rule id="GL_SOFT_OPT_CO_FIN" name="co fin de soft optional" default="off">
      <pattern>
        <token>co</token>
        <token>fin</token>
        <token>de</token>
      </pattern>
      <message>Considere "para" ou "para que".</message>
      <short>style</short>
    </rule>
    <rule id="GL_SOFT_OPT_EN_RELACION" name="en relación con soft optional" default="off">
      <pattern>
        <token>en</token>
        <token>relación</token>
        <token>con</token>
      </pattern>
      <message>Considere "sobre" ou "respecto a".</message>
      <short>style</short>
    </rule>
  </category>
</rules>
