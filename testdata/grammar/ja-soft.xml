        <token>yo</token>
        <token>yo</token>
      </pattern>
      <message>Possible repeated "yo".</message>
      <short>yo yo</short>
    </rule>
  </category>
  <category id="TYPOGRAPHY" name="Typography">
    <rule id="JA_SOFT_DOUBLE_Q" name="double question">
      <pattern>
        <token>?</token>
        <token>?</token>
      </pattern>
      <message>Often one question mark is enough: "?"</message>
      <short>!!</short>
    </rule>
    <rule id="JA_SOFT_DOUBLE_BANG" name="double bang">
      <pattern>
        <token>!</token>
        <token>!</token>
      </pattern>
      <message>Often one exclamation mark is enough: "!"</message>
      <short>!!</short>
    </rule>
  </category>
</rules>
