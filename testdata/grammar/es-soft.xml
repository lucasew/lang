<?xml version="1.0" encoding="UTF-8"?>
<rules lang="es">
  <category id="GRAMMAR" name="Grammar">
    <rule id="ES_SOFT_HAYA_ALLA" name="haya/allá">
      <pattern>
        <token>voy</token>
        <token>haya</token>
      </pattern>
      <message>¿Quiso decir "voy allá"?</message>
      <short>haya/allá</short>
    </rule>
    <rule id="ES_SOFT_A_EL" name="a el">
      <pattern>
        <token>a</token>
        <token>el</token>
      </pattern>
      <message>¿Quiso decir "al"?</message>
      <short>a/al</short>
    </rule>
    <rule id="ES_SOFT_DE_EL" name="de el">
      <pattern>
        <token>de</token>
        <token>el</token>
      </pattern>
      <message>¿Quiso decir "del"?</message>
      <short>de/del</short>
    </rule>
    <rule id="ES_SOFT_HAY_AY" name="hay/ay">
      <pattern>
        <token>ay</token>
        <token>que</token>
      </pattern>
      <message>¿Quiso decir "hay que"?</message>
      <short>hay/ay</short>
    </rule>
    <rule id="ES_SOFT_SINO_SI_NO" name="sino/si no">
      <pattern>
        <token>si</token>
        <token>no</token>
        <token>vienes</token>
      </pattern>
      <message>Compruebe si corresponde "si no" o "sino".</message>
      <short>sino</short>
    </rule>
    <rule id="ES_SOFT_HA_A" name="ha/a">
      <pattern>
        <token>a</token>
        <token>ido</token>
      </pattern>
      <message>¿Quiso decir "ha ido"?</message>
      <short>ha/a</short>
    </rule>
    <rule id="ES_SOFT_PORQUE" name="por que">
      <pattern>
        <token>por</token>
        <token>que</token>
      </pattern>
      <message>¿Quiso decir "porque" o "por qué"?</message>
      <short>porque</short>
    </rule>
    <rule id="ES_SOFT_EN_EL" name="en el ok">
      <pattern>
        <token>en</token>
        <token>el</token>
        <token>el</token>
      </pattern>
      <message>Posible repetición de "el".</message>
      <short>el el</short>
    </rule>
    <rule id="ES_SOFT_HAZ_HAS" name="haz/has">
      <pattern>
        <token>tu</token>
        <token>haz</token>
      </pattern>
      <message>¿Quiso decir "tú has"?</message>
      <short>haz/has</short>
    </rule>
    <rule id="ES_SOFT_VALLA_VAYA" name="valla/vaya">
      <pattern>
        <token>valla</token>
        <token>usted</token>
      </pattern>
      <message>¿Quiso decir "vaya usted"?</message>
      <short>valla/vaya</short>
    </rule>
    <rule id="ES_SOFT_ECHO_HECHO" name="echo/hecho">
      <pattern>
        <token>he</token>
        <token>echo</token>
      </pattern>
      <message>¿Quiso decir "he hecho"?</message>
      <short>echo/hecho</short>
    </rule>
    <rule id="ES_SOFT_AYA_HAYA" name="aya/haya">
      <pattern>
        <token>aya</token>
        <token>visto</token>
      </pattern>
      <message>¿Quiso decir "haya visto"?</message>
      <short>aya/haya</short>
    </rule>
  </category>
  <category id="TYPOGRAPHY" name="Tipografía">
    <rule id="ES_SOFT_DOUBLE_BANG" name="doble exclamación">
      <pattern>
        <token>!</token>
        <token>!</token>
      </pattern>
      <message>Considere un solo signo de exclamación: "!"</message>
      <short>puntuación</short>
    </rule>
  </category>
</rules>
