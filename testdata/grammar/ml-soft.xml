<?xml version="1.0" encoding="UTF-8"?>
<rules lang="ml">
  <category id="GRAMMAR" name="Grammar">
    <rule id="ML_SOFT_UM_UM" name="um um">
      <pattern>
        <token>um</token>
        <token>um</token>
      </pattern>
      <message>Possible repeated "um".</message>
      <short>um um</short>
    </rule>
    <rule id="ML_SOFT_OR_OR" name="or or">
      <pattern>
        <token>or</token>
        <token>or</token>
      </pattern>
      <message>Possible repeated "or".</message>
      <short>or or</short>
    </rule>
    <rule id="ML_SOFT_AND_AND" name="and and">
      <pattern>
        <token>and</token>
        <token>and</token>
      </pattern>
      <message>Possible repeated "and".</message>
      <short>and and</short>
    </rule>
  </category>
</rules>
