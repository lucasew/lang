<?xml version="1.0" encoding="UTF-8"?>
<rules lang="tl">
  <category id="GRAMMAR" name="Grammar">
    <rule id="TL_SOFT_AT_AT" name="at at">
      <pattern>
        <token>at</token>
        <token>at</token>
      </pattern>
      <message>Posibleng ulit ng "at".</message>
      <short>at at</short>
    </rule>
    <rule id="TL_SOFT_NG_NG" name="ng ng">
      <pattern>
        <token>ng</token>
        <token>ng</token>
      </pattern>
      <message>Posibleng ulit ng "ng".</message>
      <short>ng ng</short>
    </rule>
    <rule id="TL_SOFT_SA_SA" name="sa sa">
      <pattern>
        <token>sa</token>
        <token>sa</token>
      </pattern>
      <message>Posibleng ulit ng "sa".</message>
      <short>sa sa</short>
    </rule>
    <rule id="TL_SOFT_ANG_ANG" name="ang ang">
      <pattern>
        <token>ang</token>
        <token>ang</token>
      </pattern>
      <message>Posibleng ulit ng "ang".</message>
      <short>ang ang</short>
    </rule>
    <rule id="TL_SOFT_NA_NA" name="na na">
      <pattern>
        <token>na</token>
        <token>na</token>
      </pattern>
      <message>Posibleng ulit ng "na".</message>
      <short>na na</short>
    </rule>
    <rule id="TL_SOFT_AY_AY" name="ay ay">
      <pattern>
        <token>ay</token>
        <token>ay</token>
      </pattern>
      <message>Posibleng ulit ng "ay".</message>
      <short>ay ay</short>
    </rule>
  </category>
  <category id="TYPOGRAPHY" name="Typography">
    <rule id="TL_SOFT_DOUBLE_BANG" name="double bang">
      <pattern>
        <token>!</token>
        <token>!</token>
      </pattern>
      <message>Madalas sapat ang isang tandang padamdam: "!"</message>
      <short>!!</short>
    </rule>
  </category>
</rules>
