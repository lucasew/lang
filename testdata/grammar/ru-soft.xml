<?xml version="1.0" encoding="UTF-8"?>
<rules lang="ru">
  <category id="GRAMMAR" name="Grammar">
    <rule id="RU_SOFT_V_V" name="в в">
      <pattern>
        <token>в</token>
        <token>в</token>
      </pattern>
      <message>Возможный повтор "в".</message>
      <short>в в</short>
    </rule>
    <rule id="RU_SOFT_I_I" name="и и">
      <pattern>
        <token>и</token>
        <token>и</token>
      </pattern>
      <message>Возможный повтор "и".</message>
      <short>и и</short>
    </rule>
    <rule id="RU_SOFT_NA_NA" name="на на">
      <pattern>
        <token>на</token>
        <token>на</token>
      </pattern>
      <message>Возможный повтор "на".</message>
      <short>на на</short>
    </rule>
    <rule id="RU_SOFT_NE_NE" name="не не">
      <pattern>
        <token>не</token>
        <token>не</token>
      </pattern>
      <message>Возможный повтор "не".</message>
      <short>не не</short>
    </rule>
    <rule id="RU_SOFT_S_S" name="с с">
      <pattern>
        <token>с</token>
        <token>с</token>
      </pattern>
      <message>Возможный повтор "с".</message>
      <short>с с</short>
    </rule>
    <rule id="RU_SOFT_PO_PO" name="по по">
      <pattern>
        <token>по</token>
        <token>по</token>
      </pattern>
      <message>Возможный повтор "по".</message>
      <short>по по</short>
    </rule>
    <rule id="RU_SOFT_ETO_ETO" name="это это">
      <pattern>
        <token>это</token>
        <token>это</token>
      </pattern>
      <message>Возможный повтор "это".</message>
      <short>это это</short>
    </rule>
  </category>
  <category id="TYPOGRAPHY" name="Типографика">
    <rule id="RU_SOFT_DOUBLE_BANG" name="двойной восклицательный">
      <pattern>
        <token>!</token>
        <token>!</token>
      </pattern>
      <message>Часто достаточно одного знака: "!"</message>
      <short>пунктуация</short>
    </rule>
  </category>
</rules>
